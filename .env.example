# Copy this file to `.env` and fill in your own values.
# NEVER commit `.env` — it is gitignored. This `.env.example` documents what's
# required, with no real values.

# --- Database (Supabase Postgres) ---
# Supabase dashboard -> Project Settings -> Database -> Connection string (URI).
DATABASE_URL=

# --- Reddit API (create an app at https://www.reddit.com/prefs/apps -> "script") ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Reddit requires a descriptive User-Agent; put your real reddit username.
REDDIT_USER_AGENT=catalyst-tracker/0.1 by u/your_reddit_username

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=

# --- Optional tunables ---
# Comma-separated subreddits to track (no "r/" prefix).
TRACKED_SUBREDDITS=SaaS,startups,Entrepreneur
# Domain treated as the "client" (posts linking here count as our content).
CLIENT_DOMAIN=
