# Copy this file to `.env` and fill in your own values.
# NEVER commit `.env` — it is gitignored. This `.env.example` documents what's
# required, with no real values.

# --- Database (Supabase Postgres) ---
# Supabase dashboard -> Connect -> Session pooler -> copy the URI.
DATABASE_URL=

# --- YouTube Data API v3 (Google Cloud -> APIs & Services -> Credentials -> API key) ---
# Use a "public data" API key (no OAuth needed for public video stats).
YOUTUBE_API_KEY=

# Comma-separated YouTube channel IDs or @handles to track (the client + the field).
YOUTUBE_CHANNELS=
# Which of the above is "the client" (its videos are tagged as our content).
CLIENT_CHANNEL=

# --- Google Gemini (free tier; https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=

# --- Optional ---
# Domain treated as the "client" (videos whose description links here count as our content).
CLIENT_DOMAIN=
